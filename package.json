{
	"name": "phoxiv",
	"version": "0.0.1",
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/dm-sans": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@leeoniya/ufuzzy": "^1.0.19",
		"@lucide/svelte": "^1.14.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.6.0",
		"@types/sanitize-html": "^2.16.1",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"csv-parse": "^6.2.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"formsnap": "^2.0.1",
		"globals": "^17.5.0",
		"js-yaml": "^4.1.1",
		"marked": "^18.0.0",
		"mdsvex": "^0.12.7",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.8.2",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"sanitize-html": "^2.17.3",
		"svelte": "^5.55.3",
		"svelte-check": "^4.4.6",
		"svelte-seo": "^2.0.0",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.59.0",
		"vite": "^8.0.8",
		"wrangler": "^4.84.1",
		"zod": "^4.4.2"
	},
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "bun run build && wrangler dev",
		"deploy": "bun run build && wrangler deploy",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply DB",
		"db:migrate-remote": "wrangler d1 migrations apply DB --remote",
		"db:studio": "drizzle-kit studio",
		"cf-typegen": "wrangler types ./src/worker-configuration.d.ts",
		"pregen": "bun run ./src/lib/pregen/generate.ts",
		"sync:pull": "rclone sync r2:phoxiv-files/ files/ --progress",
		"sync:push": "rclone sync files/ r2:phoxiv-files/ --progress",
		"migrate:d1": "FILES_BASE_URL=https://cdn.phoxiv.org bun run src/lib/pregen/migrate-to-d1.ts"
	},
	"type": "module"
}
